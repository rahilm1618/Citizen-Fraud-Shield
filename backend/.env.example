# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/citizen_fraud_shield

# LLM Provider: "openai" or "gemini" or "groq"
LLM_PROVIDER=groq

# Groq
GROQ_API_KEY=your-groq-key-here

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here

# Google Gemini (optional, used when LLM_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-pro

# JWT
JWT_SECRET=change-me-to-a-random-secret-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
